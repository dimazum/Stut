@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.Extensions.Hosting
@using System.Text.Json
@using Microsoft.Extensions.Localization

@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IStringLocalizer<Shared> L

@{
    var disableStuContainer = ViewData["disableStuContainer"] as bool? == true;
    var manifest = new Dictionary<string, string>();
    if (!Env.IsDevelopment())
    {
        manifest = JsonSerializer.Deserialize<Dictionary<string,string>>(
            System.IO.File.ReadAllText(
                System.IO.Path.Combine(Env.WebRootPath, "angular/manifest.json")
            )
        );
    }
    
    var userAgent = Context.Request.Headers["User-Agent"].ToString();
    var isBot = userAgent.Contains("Googlebot") || userAgent.Contains("Bingbot") || userAgent.Contains("Yandex");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | SpeechFlow</title>
    <meta name="description" content="@ViewData["Description"]" />
    <meta name="keywords" content="@ViewData["Keywords"]" />

    <meta name="description" content="Онлайн-тренажер для лечения заикания." />
    
    @if (!Env.IsDevelopment())
    {
        <link rel="stylesheet" href="/angular/@manifest["styles"]" />
    }
    else
    {
        <link rel="stylesheet" href="http://localhost:4200/styles.css" />
    }

</head>
<body>

<header class="desktop-header">
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Index", "Home")">
                <img src="~/images/logo.png" alt="SpeechFlow" />
                <span>SpeechFlow</span>
            </a>
        </div>

        <nav class="desktop-nav">
            <ul class="nav-menu">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "home")">@L["Main"]</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "dailyLesson")">@L["DailyLesson"]</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "calendar")">@L["Calendar"]</a>
                </li>

                <li class="nav-item has-submenu">
                    <span class="nav-link">
                        @L["Exercises"]
                    </span>
                    <ul class="submenu">
                        <li><a href="@Url.Action("Index", "texts")">@L["Texts"]</a></li>
                        <li><a href="@Url.Action("Index", "practiceWord")">@L["PracticeWord"]</a></li>
                        <li><a href="@Url.Action("Index", "inBackground")">@L["TaskInBackground"]</a></li>
                    </ul>
                </li>

                <li class="nav-item has-submenu">
                    <span class="nav-link">
                        @L["Methodology"]
                    </span>
                    <ul class="submenu">
                        <li><a href="@Url.Action("Index", "aboutMethodology")">@L["AboutMethodology"]</a></li>
                        <li><a href="@Url.Action("Index", "roboticVoice")">@L["RoboticVoice"]</a></li>
                        <li><a href="@Url.Action("Index", "howToRead")">@L["HowToRead"]</a></li>
                    </ul>
                </li>
                <li class="nav-item has-submenu">
                    <span class="nav-link">
                        @L["VoiceAnalysis"]
                    </span>
                    <ul class="submenu">
                        <li><a href="@Url.Action("Index", "texts")">@L["Records"]</a></li>
                    </ul>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "linkedAccounts")">@L["LinkedAccounts"]</a>
                </li>

                @* <li class="nav-item"> *@
                @*     <a class="nav-link" href="@Url.Action("Index", "aboutProject")">О проекте</a> *@
                @* </li> *@
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "admin")">Admin</a>
                    </li>
                }
            </ul>
        </nav>
        @await Component.InvokeAsync("LanguagePicker")
        <app-account></app-account>
    </div>
</header>

<!-- Mobile header -->
<header class="mobile-header">
    <div class="mobile-header-container">
        <div class="mobile-logo">
            <a href="@Url.Action("Index", "home")">
                <img src="~/images/logo.png" alt="SpeechFlow" />
                <span>SpeechFlow</span>
            </a>
        </div>
        <div class="mobile-account">
            <app-account></app-account>
        </div>
        <button class="burger" id="burgerBtn" aria-label="Меню">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
    <nav class="mobile-nav" id="mobileNav">
        <ul>
            <li><a href="@Url.Action("Index", "home")">Главная</a></li>
            <li><a href="@Url.Action("Index", "dailyLesson")">Дневной урок</a></li>
            <li><a href="@Url.Action("Index", "calendar")">Календарь</a></li>
            <li><a href="@Url.Action("Index", "texts")">Тексты</a></li>
            <li class="has-submenu">
                <button class="submenu-toggle">
                    Упражнения
                    <span class="arrow"></span>
                </button>

                <ul class="submenu">
                    <li><a href="@Url.Action("Index", "breathing")">Дыхание</a></li>
                    <li><a href="/Home/Exercises/Diction">Дикция</a></li>
                    <li><a href="/Home/Exercises/Intonation">Интонация</a></li>
                    <li><a href="/Home/Exercises/Voice">Голос</a></li>
                </ul>
            </li>
            <li><a href="/Home/VoiceAnalisys">Анализ голоса</a></li>
            <li><a href="/Home/AboutProject">О проекте</a></li>
        </ul>
    </nav>
</header>

<main class="@(disableStuContainer ?  null : "stu-container")">
    @RenderBody()
</main>

<app-root></app-root>

@if (!Env.IsDevelopment())
{
    <script src="/angular/@manifest["polyfills"]" type="module"></script>
    <script src="/angular/@manifest["main"]" type="module"></script>
}
else
{
    <script type="module" src="http://localhost:4200/main.js"></script>
}

@if (isBot)
{
    <footer>
        <p>© @DateTime.Now.Year — SpeechFlow</p>
        <nav>
            <a href="/home">Главная</a>
            <a href="/about">О проекте</a>
        </nav>
    </footer>
}
</body>
</html>