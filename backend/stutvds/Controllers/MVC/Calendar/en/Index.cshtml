@{
    Layout = "_Layout";

    ViewData["Title"] = "Speech Progress Calendar — track your training";
    ViewData["Description"] = "Track your progress in diction, breathing, and intonation exercises with the training calendar.";
    ViewData["Keywords"] = "speech calendar, speech progress, diction exercises, voice training, speaking practice";
}

<h1 class="text-center">Speech Progress Calendar</h1>

<stu-calendar></stu-calendar>

<p>
    Track your daily training to improve diction, breathing, and intonation. 
    The calendar helps you see your progress and stay motivated to practice regularly.
</p>

<hr />

<section>
    <h2>Why keep a training calendar?</h2>
    <ul>
        <li>Stay consistent with your practice</li>
        <li>See your progress and improvements</li>
        <li>Stay motivated to practice every day</li>
        <li>Analyze your strengths and weaknesses</li>
    </ul>
</section>