@{
    Layout = "_Layout";
    
    ViewData["Title"] = "Лечение заикания онлайн — упражнения для речи и дыхания";
    ViewData["Description"] = "Онлайн тренажёр для лечения заикания: упражнения для дыхания, голоса и артикуляции, отслеживание прогресса и формирование плавной речи.";
    ViewData["Keywords"] = "лечение заикания, упражнения от заикания, тренировка речи, упражнения для дикции, развитие речи, логопед онлайн";
}

<!-- HERO -->
<div class="home">
    <section class="stu-gray hero">
        <div class="container">
            <h1>Тренажер для лечения заикания</h1>
            <p>Здесь начинается работа над собой</p>
            <a href="@Url.Action("Index", "dailyLesson")" class="stu-button-l2">Начать</a>
        </div>
    </section>

    <!-- FOR WHOM -->
    <section class="progress-section">
        <div class="container">
            <h2>Для кого этот сайт</h2>
            <div class="inner-container">
                <img src="~/images/forwhom.png" alt="forwhom" />
                <ul>
                    <li>Для детей и взрослых, которые заикаются</li>
                    <li>Для родителей</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="stu-gray">
        <div class="container">
            <h2>Принцип методики:</h2>
            <div class="inner-container">
                <ul>
                    <li>Вы делаете упражнения самостоятельно в спокойной атмосфере</li>
                    <li>Упражнения и тексты проговариваем в специальной позиции голосовых связок</li>
                </ul>
                <img src="~/images/howtodo.png" alt="howtodo" />
                
            </div>
        </div>
    </section>

    <!-- Coals -->
    <section>
        <div class="container">
            <h2>Наши цели:</h2>
            <ul>
                <li>Снять гипертонус мышц речевого аппарата</li>
                <li>Укрепить мышцы речевого аппарата</li>
                <li>Сформировать правильное дыхание</li>
                <li>Развить устойчивую речевую привычку</li>
            </ul>
        </div>
    </section>

    <!-- WHY -->
    <section class="stu-gray">
        <div class="container">
            <h2>Что тренируем:</h2>
            <div class="card-3">
                <div class="card">
                    <h3>Дыхание</h3>
                    <ul>
                        <li>Тренируем замедление выдоха</li>
                        <li>Тренируем выдох перед началом речи</li>
                        <li>Тренируем выдох ровными порциями</li>
                    </ul>
                </div>

                <div class="card">
                    <h3>Голосовой аппарат</h3>
                    <ul>
                        <li>Тренируем мышцы голосовых связок</li>
                        <li>Разрабатываем мышечные зажимы</li>
                    </ul>
                </div>

                <div class="card">
                        <h3>Артикуляция</h3>
                    <ul>
                        <li>Тренируем мышцы языка, лица</li>
                        <li>Разрабатываем мышечные зажимы</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    

    <!-- WHAT YOU GET -->
    <section class="">
        <div class="container">
            <h2>Что вы получите</h2>

            <div class="card-3">
                <div class="card">
                    <div class="card-inner">
                        <img src="~/images/excercises.png" alt="exercises"/>
                        <h3>Упражнения</h3>
                    </div>
                    <p>Структурированные занятия для дыхания, голоса и артикуляции.</p>
                
                </div>

                <div class="card">
                    <div class="card-inner">
                        <img src="~/images/analysis.png" alt="analysis"/>
                        <h3>Анализ речи</h3>
                    </div>
                        <p>Автоматическая оценка темпа, плавности и стабильности голоса.</p>
                    </div>

                <div class="card">
                    <div class="card-inner">
                        <img src="~/images/private.png" alt="private"/>
                        <h3>Личный кабинет</h3>
                    </div>
                    <p>История занятий, хранение показателей и сложных слов.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="stu-gray">
        <div class="container">
            <h2>Как проходит работа</h2>

            <div class="steps">
                <div class="step">1. Регистрация</div>
                <div class="step">2. Изучаем как делать упраженения</div>
                <div class="step">3. 15-30 минут в день</div>
                <div class="step">4. Отслеживание прогресса</div>
            </div>
        </div>
    </section>
    
</div>