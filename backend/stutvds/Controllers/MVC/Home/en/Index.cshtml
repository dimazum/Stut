@{
    Layout = "_Layout";
}

<!-- HERO -->
<div class="home">
    <section class="stu-gray hero">
        <div class="container">
            <h1>Stuttering Therapy Trainer</h1>
            <p>Your journey to self-improvement starts here</p>
            <a href="/dailyLesson" class="stu-button-l2">Start</a>
        </div>
    </section>

    <!-- FOR WHOM -->
    <section class="progress-section">
        <div class="container">
            <h2>Who this site is for</h2>
            <ul>
                <li>Children and adults who stutter</li>
                <li>Parents</li>
            </ul>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="stu-gray">
        <div class="container">
            <h2>Method principle:</h2>
            <ul>
                <li>You practice exercises independently in a calm environment</li>
                <li>Exercises and texts are pronounced using a special vocal cord position</li>
            </ul>
        </div>
    </section>

    <!-- GOALS -->
    <section>
        <div class="container">
            <h2>Our goals:</h2>
            <ul>
                <li>Relieve hypertonicity of speech muscles</li>
                <li>Strengthen speech muscles</li>
                <li>Develop proper breathing</li>
                <li>Form a stable speech habit</li>
            </ul>
        </div>
    </section>

    <!-- WHAT WE TRAIN -->
    <section class="stu-gray">
        <div class="container">
            <h2>What we train:</h2>
            <div class="card-3">
                <div class="card">
                    <h3>🫁 Breathing</h3>
                    <p>Creates airflow for speech.</p>
                    <ul>
                        <li>Diaphragm development</li>
                        <li>Intercostal muscles</li>
                    </ul>
                </div>

                <div class="card">
                    <h3>🔊 Voice</h3>
                    <p>Transforms air into sound.</p>
                    <ul>
                        <li>Vocal cord muscles</li>
                    </ul>
                </div>

                <div class="card">
                    <h3>👄 Articulation</h3>
                    <p>Shapes sounds and words.</p>
                    <ul>
                        <li>Tongue muscles</li>
                        <li>Facial muscles</li>
                        <li>Palate</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="">
        <div class="container">
            <h2>What you get</h2>

            <div class="card-3">
                <div class="card">
                    <h3>📚 Exercises</h3>
                    <p>Structured sessions for breathing, voice, and articulation.</p>
                </div>

                <div class="card">
                    <h3>📊 Speech Analysis</h3>
                    <p>Automatic assessment of pace, fluency, and voice stability.</p>
                </div>

                <div class="card">
                    <h3>🗂 Personal Account</h3>
                    <p>Track session history, save metrics, and difficult words.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="stu-gray">
        <div class="container">
            <h2>How it works</h2>

            <div class="steps">
                <div class="step">1. Registration</div>
                <div class="step">2. Learn how to do exercises</div>
                <div class="step">3. 15–30 minutes a day</div>
                <div class="step">4. Track your progress</div>
            </div>
        </div>
    </section>
    
</div>