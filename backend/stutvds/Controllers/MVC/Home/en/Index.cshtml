@{
    Layout = "_Layout";
    
    ViewData["Title"] = "Stuttering Treatment App — Speech Therapy Exercises Online";
    ViewData["Description"] = "Online speech therapy exercises to reduce stuttering. Train breathing, voice and articulation, track progress and build fluent speech habits.";
    ViewData["Keywords"] = "stuttering treatment, speech therapy online, speech exercises, fluency training, stop stuttering, speech therapy app";
}

<!-- HERO -->
<div class="home">
    <section class="stu-gray hero">
        <div class="container">
            <h1>Stuttering Therapy Trainer</h1>
            <p>Your self-improvement journey starts here</p>
            <a href="@Url.Action("Index", "dailyLesson")" class="stu-button-l2">Start</a>
        </div>
    </section>

    <!-- FOR WHOM -->
    <section class="progress-section">
        <div class="container">
            <h2>Who this website is for</h2>
            <div class="inner-container">
                <img src="~/images/forwhom.png" alt="forwhom" />
                <ul>
                    <li>Children and adults who stutter</li>
                    <li>Parents</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="stu-gray">
        <div class="container">
            <h2>Method principles:</h2>
            <div class="inner-container">
                <ul>
                    <li>You practice exercises independently in a calm environment</li>
                    <li>Exercises and texts are spoken using a special vocal cord position</li>
                </ul>
                <img src="~/images/howtodo.png" alt="howtodo" />
            </div>
        </div>
    </section>

    <!-- GOALS -->
    <section>
        <div class="container">
            <h2>Our goals:</h2>
            <ul>
                <li>Reduce hypertonicity of speech muscles</li>
                <li>Strengthen speech muscles</li>
                <li>Develop proper breathing</li>
                <li>Build a stable speech habit</li>
            </ul>
        </div>
    </section>

    <!-- WHAT WE TRAIN -->
    <section class="stu-gray">
        <div class="container">
            <h2>What we train:</h2>
            <div class="card-3">
                <div class="card">
                    <h3>Breathing</h3>
                    <ul>
                        <li>Slowing down exhalation</li>
                        <li>Exhaling before starting speech</li>
                        <li>Even, controlled exhalation</li>
                    </ul>
                </div>

                <div class="card">
                    <h3>Voice apparatus</h3>
                    <ul>
                        <li>Training vocal cord muscles</li>
                        <li>Releasing muscle tension</li>
                    </ul>
                </div>

                <div class="card">
                    <h3>Articulation</h3>
                    <ul>
                        <li>Training tongue and facial muscles</li>
                        <li>Releasing muscle tension</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- WHAT YOU GET -->
    <section>
        <div class="container">
            <h2>What you get</h2>

            <div class="card-3">
                <div class="card">
                    <div class="card-inner">
                        <img src="~/images/excercises.png" alt="exercises"/>
                        <h3>Exercises</h3>
                    </div>
                    <p>Structured sessions for breathing, voice, and articulation.</p>
                </div>

                <div class="card">
                    <div class="card-inner">
                        <img src="~/images/analysis.png" alt="analysis"/>
                        <h3>Speech analysis</h3>
                    </div>
                    <p>Automatic evaluation of speech rate, fluency, and voice stability.</p>
                </div>

                <div class="card">
                    <div class="card-inner">
                        <img src="~/images/private.png" alt="private"/>
                        <h3>Personal dashboard</h3>
                    </div>
                    <p>Training history, progress tracking, and difficult word storage.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW THE PROCESS WORKS -->
    <section class="stu-gray">
        <div class="container">
            <h2>How the process works</h2>

            <div class="steps">
                <div class="step">1. Registration</div>
                <div class="step">2. Learn how to do the exercises</div>
                <div class="step">3. 15–30 minutes per day</div>
                <div class="step">4. Track your progress</div>
            </div>
        </div>
    </section>
    
</div>